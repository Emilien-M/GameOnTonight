@page "/history"
@using GameOnTonight.RestClient
@attribute [Authorize]
@inject Client ApiClient

<PageTitle>Historique des parties</PageTitle>

<h1 class="mb-4">Historique des parties</h1>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        @errorMessage
        <button type="button" class="btn-close float-end" @onclick="() => errorMessage = null"></button>
    </div>
}
else if (gameSessions == null || !gameSessions.Any())
{
    <div class="alert alert-info">
        <p>Vous n'avez pas encore enregistré de parties.</p>
        <p>Utilisez la <a href="/">page d'accueil</a> pour filtrer votre ludothèque et commencer à enregistrer vos parties!</p>
    </div>
}
else
{
    <div class="mb-4">
        <label for="historyCount" class="form-label">Nombre de parties à afficher:</label>
        <div class="d-flex align-items-center">
            <select id="historyCount" class="form-select w-auto me-3" @bind="historyCount">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="0">Toutes</option>
            </select>
            <button class="btn btn-primary" @onclick="LoadGameSessions">Actualiser</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Jeu</th>
                    <th>Joueurs</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in gameSessions)
                {
                    <tr>
                        <td>@session.PlayedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <strong>@session.BoardGameName</strong>
                        </td>
                        <td>@session.PlayerCount</td>
                        <td>
                            @if (string.IsNullOrEmpty(session.Notes))
                            {
                                <span class="text-muted">Aucune note</span>
                            }
                            else
                            {
                                @session.Notes
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSessionPrompt(session)">
                                <i class="oi oi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (showStatistics)
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">Statistiques</h5>
            </div>
            <div class="card-body">
                @if (statistics == null || !statistics.Any())
                {
                    <p>Chargement des statistiques...</p>
                }
                else
                {
                    <div class="row">
                        @foreach (var stat in statistics)
                        {
                            <div class="col-md-3 mb-3">
                                <div class="card border-light">
                                    <div class="card-body text-center">
                                        <h3>@stat.Value</h3>
                                        <p class="text-muted">@stat.Key</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer cette partie de l'historique ?</p>
                    <p><strong>Jeu :</strong> @(sessionToDelete?.BoardGameName)</p>
                    <p><strong>Date :</strong> @(sessionToDelete?.PlayedAt.ToString("dd/MM/yyyy HH:mm"))</p>
                    <p class="text-danger"><strong>Cette action est irréversible.</strong></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteSession">Supprimer</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ICollection<GameSessionViewModel>? gameSessions;
    private IDictionary<string, int>? statistics;
    private int historyCount = 10; // Par défaut, afficher les 10 dernières parties
    private bool isLoading = true;
    private bool showStatistics = true;
    private string? errorMessage;
    private bool showDeleteConfirm = false;
    private GameSessionViewModel? sessionToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadGameSessions();
        await LoadStatistics();
    }

    private async Task LoadGameSessions()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Si historyCount est à 0, on récupère toutes les parties
            gameSessions = await ApiClient.GameSessionsGetHistoryAsync(historyCount == 0 ? null : historyCount);
            
            // Trier par date décroissante (plus récente en premier)
            gameSessions = gameSessions.OrderByDescending(s => s.PlayedAt).ToList();
        }
        catch (ApiException ex)
        {
            errorMessage = $"Erreur lors du chargement de l'historique: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Une erreur inattendue s'est produite: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadStatistics()
    {
        try
        {
            statistics = await ApiClient.GameSessionsGetGamePlayCountsAsync();
        }
        catch
        {
            // Si l'API de statistiques échoue, on continue sans les statistiques
            showStatistics = false;
        }
    }

    private void DeleteSessionPrompt(GameSessionViewModel session)
    {
        sessionToDelete = session;
        showDeleteConfirm = true;
    }

    private async Task ConfirmDeleteSession()
    {
        if (sessionToDelete == null) return;

        try
        {
            await ApiClient.GameSessionsDeleteByIdAsync(sessionToDelete.Id);
            showDeleteConfirm = false;
            sessionToDelete = null;
            await LoadGameSessions();
            await LoadStatistics();
        }
        catch (ApiException ex)
        {
            errorMessage = $"Erreur lors de la suppression: {ex.Message}";
            showDeleteConfirm = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Une erreur inattendue s'est produite: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}
